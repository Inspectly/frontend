{
  "expo": {
    "name": "Inspectly Pro",
    "slug": "inspectly-vendor",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "inspectly-vendor",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1A1A1A"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.inspectly.vendor"
    },
    "android": {
      "package": "com.inspectly.vendor"
    },
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
